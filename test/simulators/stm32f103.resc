# STM32F103 (C8T6) (mcu_mdt example)
# Connect with: nc localhost 3456

mach create
machine LoadPlatformDescription @platforms/cpus/stm32f103.repl

# STM32F103C8T6 specifics: 64KB flash, 20KB SRAM
# machine LoadPlatformDescriptionFromString "flash: Memory.MappedMemory @ sysbus 0x08000000 { size: 0x10000 }"
# machine LoadPlatformDescriptionFromString "sram: Memory.MappedMemory @ sysbus 0x20000000 { size: 0x5000 }"

sysbus LoadELF @build/F103C8/mcu_mdt_example.elf

# Expose USART1 as a raw TCP socket on port 3456
# 'false' disables the telnet negotiation bytes(important for binary protocols)
emulation CreateServerSocketTerminal 3456 "uart_term" false
connector Connect sysbus.usart1 uart_term

machine StartGdbServer 3333 true

start